---
// Page-level crossfade for reading switches. When the reading changes, a fixed
// overlay painted with the PREVIOUS reading's background fades from opacity 1 to
// 0 over 380ms. The content underneath snaps to the new reading immediately, so
// the overlay does the visual work — more reliable than transitioning inherited
// custom properties. Covers both the hero toggle and The Work toggle, since both
// flow through the shared reading.ts module. Disabled under reduced motion.
---

<div id="reading-overlay" aria-hidden="true"></div>

<style>
  #reading-overlay {
    position: fixed;
    inset: 0;
    z-index: 90;
    pointer-events: none;
    opacity: 0;
  }
  #reading-overlay.run {
    animation: reading-crossfade 380ms cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  @keyframes reading-crossfade {
    from { opacity: 1; }
    to { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    #reading-overlay.run { animation: none; opacity: 0; }
  }
</style>

<script>
  import { onReading, getReading, type Reading } from '../lib/reading.ts';

  const overlay = document.getElementById('reading-overlay');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
  const BG: Record<Reading, string> = { auditor: '#F0EBE3', builder: '#0C1519' };

  if (overlay) {
    let prev: Reading = getReading();
    onReading((r) => {
      if (r === prev) return;
      if (!reduce.matches) {
        overlay.style.backgroundColor = BG[prev];
        overlay.classList.remove('run');
        void overlay.offsetWidth; // force reflow so the animation restarts
        overlay.classList.add('run');
      }
      prev = r;
    });
  }
</script>
