---
const books = [
  {
    title: 'The Enigma of Reason',
    author: 'Hugo Mercier & Dan Sperber',
    color: '#2c3e50',
    cover: '/img/books/enigma-of-reason.png',
    brief: 'A groundbreaking theory of why humans reason — not to find truth, but to argue. Mercier and Sperber make the case that reason evolved as a social tool for persuasion and evaluation, not individual problem-solving.',
  },
  {
    title: 'The Art of Doing Science and Engineering',
    author: 'Richard Hamming',
    color: '#8b2500',
    cover: '/img/books/art-of-science.png',
    brief: 'Hamming\'s distilled wisdom on what separates good work from great. Less about technique, more about learning to aim at problems that matter — and developing the taste to tell the difference.',
  },
  {
    title: 'The Restaurant at the End of the Universe',
    author: 'Douglas Adams',
    color: '#1a1a2e',
    cover: '/img/books/restaurant-universe.png',
    brief: 'The sequel to Hitchhiker\'s Guide. Adams at his sharpest — bureaucracy, existential dread, and the Total Perspective Vortex, all delivered with the deadpan absurdity that makes you laugh and then think.',
  },
  {
    title: 'Discourses of Epictetus',
    author: 'Epictetus',
    color: '#3b4a3a',
    cover: '/img/books/discourses-epictetus.png',
    brief: 'The original operating manual for navigating what you can and can\'t control. Not the watered-down Stoicism of Instagram — the real thing, direct and uncompromising.',
  },
];
---

<section class="outside" id="outside" aria-labelledby="outside-h">
  <div class="wrap">
    <p class="eyebrow">Outside the work</p>
    <h2 id="outside-h">The rest of it.</h2>
    <div class="strands">
      <div class="strand strand-reading">
        <h3 class="mono">Reading</h3>
        <div class="books-grid">
          {books.map((b, i) => (
            <div class="book-slot" data-index={i}>
              <button class="book-3d" aria-expanded="false" style={`--book-color: ${b.color}`}>
                <div class="book-body">
                  <div class="book-spine"></div>
                  <div class="book-pages"></div>
                  <div class="book-front">
                    <img src={b.cover} alt={`${b.title} by ${b.author}`} class="book-cover-img" loading="lazy" />
                  </div>
                  <div class="book-back"></div>
                </div>
              </button>
              <div class="book-brief" aria-hidden="true">
                <div class="brief-inner">
                  <p class="brief-title">{b.title}</p>
                  <p class="brief-author mono">{b.author}</p>
                  <p class="brief-text">{b.brief}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="strand">
        <h3 class="mono">What I'm chasing</h3>
        <p>Everything I'm building comes from trying to understand something I don't yet. I've landed on the belief that the best moment to have a hard problem is today. Not because it gets easier, but because you're already in it.</p>
      </div>
      <div class="strand">
        <h3 class="mono">Off the clock</h3>
        <p>I surf when the ocean cooperates. I take coffee too seriously and I collect Hot Wheels — the latter started in childhood and I've never found a good reason to stop.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .outside {
    background: var(--audit-bg);
    color: var(--audit-fg);
    padding: var(--section-gap) 0;
    border-top: 1px solid var(--audit-line);
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  :global(html[data-reading='builder']) .outside {
    background: var(--build-bg);
    color: var(--build-fg);
    border-top-color: var(--build-line);
  }
  .eyebrow { color: var(--audit-accent); margin-bottom: var(--s-4); }
  :global(html[data-reading='builder']) .eyebrow { color: var(--build-accent); }
  h2 { font-family: var(--serif); font-size: var(--fs-h2); font-weight: 600; letter-spacing: -0.02em; }
  :global(html[data-reading='builder']) h2 { font-family: var(--sans); font-weight: 500; }
  .strands { margin-top: var(--s-7); display: grid; gap: var(--s-6); }
  .strand { display: grid; grid-template-columns: 180px 1fr; gap: var(--s-5); padding-top: var(--s-5); border-top: 1px solid var(--audit-line); }
  :global(html[data-reading='builder']) .strand { border-top-color: var(--build-line); }
  .strand-reading { align-items: start; }
  h3 { font-size: var(--fs-label); letter-spacing: 0.08em; text-transform: uppercase; color: var(--audit-accent); font-weight: 500; padding-top: 4px; }
  :global(html[data-reading='builder']) h3 { color: var(--build-accent); }
  .strand p { font-size: var(--fs-body); line-height: 1.5; max-width: 56ch; }

  /* ---- 2x2 grid ---- */
  .books-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-6) var(--s-5);
  }

  .book-slot {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-4);
  }

  /* ---- 3D book ---- */
  .book-3d {
    all: unset;
    cursor: pointer;
    display: block;
    box-sizing: border-box;
    width: 160px;
    height: 220px;
    perspective: 600px;
  }

  .book-body {
    --spine: 40px;
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    transform: rotateY(-25deg);
    transition: transform 0.45s var(--ease);
  }
  .book-3d:hover .book-body {
    transform: rotateY(-35deg);
  }
  .book-3d[aria-expanded="true"] .book-body {
    transform: rotateY(-12deg);
  }

  /* Front cover — pushed forward by half the spine depth */
  .book-front {
    position: absolute;
    inset: 0;
    background: var(--book-color);
    overflow: hidden;
    border-radius: 0 2px 2px 0;
    transform: translateZ(calc(var(--spine) / 2));
    box-shadow: 4px 4px 12px rgba(0,0,0,0.25);
  }
  .book-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Back cover — pushed back by half the spine depth */
  .book-back {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--book-color), black 15%);
    border-radius: 0 2px 2px 0;
    transform: translateZ(calc(var(--spine) / -2));
  }

  /* Spine — left edge, rotated 90deg, full depth */
  .book-spine {
    position: absolute;
    top: 0;
    left: 0;
    width: var(--spine);
    height: 100%;
    background: color-mix(in srgb, var(--book-color), black 25%);
    transform: rotateY(90deg) translateZ(0px);
    transform-origin: left center;
    border-radius: 2px 0 0 2px;
  }

  /* Pages — right edge, opposite the spine */
  .book-pages {
    position: absolute;
    top: 4px;
    right: 0;
    width: var(--spine);
    height: calc(100% - 8px);
    background: repeating-linear-gradient(
      to right,
      #f5f2ec,
      #f5f2ec 2px,
      #e8e4dc 2px,
      #e8e4dc 3px
    );
    transform: rotateY(-90deg) translateZ(0px);
    transform-origin: right center;
    box-shadow: inset 2px 0 4px rgba(0,0,0,0.08);
  }

  /* Top edge of pages */
  .book-body::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--spine);
    background: linear-gradient(to bottom, #f0ece4, #e4e0d8);
    transform: rotateX(90deg) translateZ(0px);
    transform-origin: top center;
  }

  /* Bottom edge of pages */
  .book-body::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: var(--spine);
    background: linear-gradient(to top, #ebe7df, #e4e0d8);
    transform: rotateX(-90deg) translateZ(0px);
    transform-origin: bottom center;
  }

  /* ---- Brief panel ---- */
  .book-brief {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.4s var(--ease), opacity 0.3s var(--ease) 0.05s;
    text-align: center;
    max-width: 280px;
  }
  .book-brief[data-open] {
    max-height: 500px;
    opacity: 1;
  }

  .brief-title {
    font-family: var(--serif);
    font-size: 16px;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: 2px;
  }
  .brief-author {
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--audit-dim);
    margin-bottom: var(--s-3);
  }
  :global(html[data-reading='builder']) .brief-author { color: var(--build-dim); }
  .brief-text {
    font-size: 14px;
    line-height: 1.55;
    color: var(--audit-dim);
  }
  :global(html[data-reading='builder']) .brief-text { color: var(--build-dim); }

  @media (max-width: 560px) {
    .strand { grid-template-columns: 1fr; gap: var(--s-2); }
    .books-grid { gap: var(--s-5) var(--s-4); }
    .book-3d { width: 120px; height: 170px; }
    .book-body { --spine: 30px; }
    .brief-title { font-size: 14px; }
    .brief-text { font-size: 13px; }
  }
</style>

<script>
  document.querySelectorAll('.book-slot').forEach((slot) => {
    const btn = slot.querySelector('.book-3d');
    const brief = slot.querySelector('.book-brief');
    btn.addEventListener('click', () => {
      const wasOpen = brief.hasAttribute('data-open');
      document.querySelectorAll('.book-brief').forEach((b) => {
        b.removeAttribute('data-open');
        b.setAttribute('aria-hidden', 'true');
      });
      document.querySelectorAll('.book-3d').forEach((b) => {
        b.setAttribute('aria-expanded', 'false');
      });
      if (!wasOpen) {
        brief.setAttribute('data-open', '');
        brief.setAttribute('aria-hidden', 'false');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
