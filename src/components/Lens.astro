---
// Annotated Monolith hero. Stage 1: the name fills the viewport. Stage 2: an
// annotated identity layer with a margin slot that fills on superscript hover.
---

<section class="hero" id="lens" aria-label="Introduction">
  <!-- Stage 1: Monolith -->
  <div class="monolith" id="monolith">
    <p class="role" id="hero-role">GRC Lead Auditor &amp; Security Builder</p>
    <div class="name-wrap" id="name-wrap">
      <h1 class="name" id="name-heading">Saqlain Momin</h1>
      <canvas class="name-canvas" id="name-canvas" aria-hidden="true"></canvas>
    </div>

    <div class="scroll-cue" id="scroll-cue" aria-hidden="true">
      <span class="scroll-cue-line"></span>
      <span class="mono">scroll</span>
    </div>
  </div>

  <!-- Stage 2: Annotation Layer -->
  <div class="annotation-layer">
    <aside class="margin" aria-label="Footnotes">
      <div class="fn-hint" aria-hidden="true">
        <span class="fn-hint-arrow">↑</span>
        <span class="mono">hover the<br>superscripts</span>
      </div>
      <div class="fn-slot" aria-live="polite">
        <span class="fn-slot-num"></span>
        <p class="fn-slot-text"></p>
      </div>
    </aside>

    <div class="main-text">
      <h2 class="headline">
        I see <sup data-ref="3" tabindex="0">3</sup>risk at the <sup data-ref="4" tabindex="0">4</sup>enterprise level, and I build the <sup data-ref="5" tabindex="0">5</sup>tools to close the <sup data-ref="6" tabindex="0">6</sup>gaps I find.
      </h2>

      <p class="sub sub-audit">
        Four years building controls at enterprise scale&thinsp;&mdash;&thinsp;I
        know why a control exists, who owns it, and what breaks when it doesn&rsquo;t.
      </p>
      <p class="sub sub-build" aria-hidden="true">
        Async Python, FastAPI, the Anthropic SDK, Swift, n8n. Understand by
        shipping.
      </p>

      <div
        class="lens-toggle"
        id="lens-toggle"
        role="slider"
        tabindex="0"
        aria-label="Reading lens"
        aria-valuemin="0"
        aria-valuemax="1"
        aria-valuenow="0"
        aria-valuetext="Auditor reading"
      >
        <span class="indicator" aria-hidden="true"></span>
        <button type="button" data-set="auditor" aria-pressed="true">Auditor</button>
        <span class="divider" aria-hidden="true"></span>
        <button type="button" data-set="builder" aria-pressed="false">Builder</button>
      </div>

      <p class="credentials credentials-audit">
        <span class="mono">ISO 27001 &middot; ISO 27701 &middot; ISO 22301</span> &mdash; Lead Auditor
      </p>
      <p class="credentials credentials-build" aria-hidden="true">
        <span class="mono">Python &middot; FastAPI &middot; Claude SDK &middot; Swift</span>
      </p>
    </div>
  </div>

  <!-- Seam to ClosingWindow -->
  <div class="seam" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--audit-bg);
    color: var(--audit-fg);
  }
  :global(html[data-reading='builder']) .hero {
    background: var(--build-bg);
    color: var(--build-fg);
  }

  /* Stage 1: Monolith */
  .monolith {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0 var(--gutter);
    position: sticky;
    top: 0;
    z-index: 1;
    overflow: hidden;
  }
  /* Profession is the lede — large, accented, the first thing read.
     The name follows as a quieter signature underneath. Both use the
     condensed display face for a tall, poster-like editorial mark. */
  .role {
    font-family: var(--display);
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(52px, 9.5vw, 140px);
    line-height: 1.04;
    letter-spacing: 0.002em;
    max-width: 16ch;
    color: var(--audit-accent);
    margin-bottom: var(--s-6);
    opacity: 0;
    animation: arrive 900ms var(--ease) 120ms both;
  }
  :global(html[data-reading='builder']) .role { color: var(--build-accent); }

  .name-wrap {
    position: relative;
    display: inline-block;
    cursor: default;
    opacity: 0;
    animation: arrive-label 700ms var(--ease) 420ms both;
  }

  @keyframes arrive {
    from { opacity: 0; transform: translateY(46px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes arrive-label {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 0.55; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .role, .name-wrap { animation: none; opacity: 1; transform: none; }
    .name-wrap { opacity: 0.55; }
  }

  /* Scroll cue — bottom of the monolith, fades out once the reader has
     actually started scrolling so it doesn't linger over Stage 2. */
  .scroll-cue {
    position: absolute;
    bottom: clamp(28px, 5vh, 56px);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s-2);
    opacity: 0;
    animation: arrive-cue 700ms var(--ease) 900ms forwards;
    transition: opacity 300ms var(--ease);
  }
  @keyframes arrive-cue {
    from { opacity: 0; transform: translate(-50%, 18px); }
    to   { opacity: 1; transform: translate(-50%, 0); }
  }
  .scroll-cue .mono {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--audit-dim);
  }
  :global(html[data-reading='builder']) .scroll-cue .mono { color: var(--build-dim); }
  .scroll-cue-line {
    width: 1px;
    height: 28px;
    background: var(--audit-line);
    position: relative;
    overflow: hidden;
  }
  :global(html[data-reading='builder']) .scroll-cue-line { background: var(--build-line); }
  .scroll-cue-line::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 40%;
    background: var(--audit-accent);
    animation: cue-drip 1.8s ease-in-out infinite;
  }
  :global(html[data-reading='builder']) .scroll-cue-line::after { background: var(--build-accent); }
  @keyframes cue-drip {
    0%   { transform: translateY(-100%); }
    60%  { transform: translateY(250%); }
    100% { transform: translateY(250%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-cue { animation: none; opacity: 1; transform: translateX(-50%); transition: none; }
    .scroll-cue-line::after { animation: none; transform: translateY(100%); }
  }
  .name {
    font-family: var(--display);
    font-weight: 500;
    text-transform: uppercase;
    font-size: clamp(30px, 5vw, 76px);
    line-height: 1.1;
    letter-spacing: 0.01em;
    color: var(--audit-dim);
  }
  :global(html[data-reading='builder']) .name {
    color: var(--build-dim);
  }
  .name:global(.canvas-active) { color: transparent !important; }
  .name-canvas {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  /* Stage 2: Annotation Layer */
  .annotation-layer {
    position: relative;
    z-index: 2;
    background: var(--audit-bg);
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: clamp(24px, 4vw, 56px);
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: clamp(48px, 8vh, 96px) var(--gutter) clamp(48px, 8vh, 80px);
  }
  :global(html[data-reading='builder']) .annotation-layer {
    background: var(--build-bg);
  }

  /* Margin column */
  .margin {
    position: sticky;
    top: clamp(48px, 8vh, 80px);
    align-self: start;
    min-height: 8em;
  }

  /* Idle hint */
  .fn-hint {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    opacity: 1;
    transition: opacity 200ms var(--ease);
  }
  .fn-hint.hidden {
    opacity: 0;
    pointer-events: none;
  }
  .fn-hint-arrow {
    font-size: 18px;
    color: var(--audit-accent);
    display: block;
    animation: nudge 2s ease-in-out infinite;
  }
  :global(html[data-reading='builder']) .fn-hint-arrow { color: var(--build-accent); }
  .fn-hint .mono {
    font-size: 11px;
    letter-spacing: 0.06em;
    line-height: 1.6;
    color: var(--audit-dim);
    opacity: 0.6;
    text-transform: uppercase;
  }
  :global(html[data-reading='builder']) .fn-hint .mono { color: var(--build-dim); }

  @keyframes nudge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  /* Footnote slot — single active annotation */
  .fn-slot {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    opacity: 0;
    transition: opacity 200ms var(--ease);
  }
  .fn-slot.active {
    opacity: 1;
  }
  .fn-slot-num {
    font-family: var(--mono);
    font-size: var(--fs-label);
    font-weight: 600;
    color: var(--audit-accent);
    display: block;
    margin-bottom: var(--s-2);
  }
  :global(html[data-reading='builder']) .fn-slot-num { color: var(--build-accent); }
  .fn-slot-text {
    font-size: var(--fs-small);
    line-height: 1.55;
    color: var(--audit-dim);
    margin: 0;
  }
  :global(html[data-reading='builder']) .fn-slot-text { color: var(--build-dim); }

  @media (prefers-reduced-motion: reduce) {
    .fn-hint-arrow { animation: none; }
    .fn-slot, .fn-hint { transition: none; }
  }

  /* Main text column */
  .main-text {
    padding-top: 0;
  }
  .headline {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(24px, 3.2vw, 40px);
    line-height: 1.3;
    letter-spacing: -0.012em;
    max-width: 26ch;
    margin-bottom: clamp(20px, 2.5vw, 32px);
  }
  :global(html[data-reading='builder']) .headline {
    font-family: var(--sans);
    font-weight: 400;
  }

  /* Superscripts — interactive hint via cursor and underline */
  .headline sup {
    font-family: var(--mono);
    font-size: 0.45em;
    font-weight: 600;
    color: var(--audit-accent);
    cursor: help;
    vertical-align: super;
    padding: 0 2px;
    text-decoration: underline dotted;
    text-underline-offset: 2px;
    transition: color 150ms var(--ease), opacity 150ms var(--ease);
  }
  :global(html[data-reading='builder']) .headline sup { color: var(--build-accent); }
  .headline sup:hover,
  .headline sup:focus-visible {
    color: var(--audit-fg);
    outline: none;
  }
  :global(html[data-reading='builder']) .headline sup:hover,
  :global(html[data-reading='builder']) .headline sup:focus-visible {
    color: var(--build-fg);
  }

  /* Sub paragraph */
  .sub {
    color: var(--audit-dim);
    max-width: 42ch;
    margin-bottom: clamp(32px, 5vh, 56px);
  }
  .sub-audit {
    font-family: var(--serif);
    font-size: clamp(16px, 1.8vw, 20px);
    line-height: 1.55;
  }
  .sub-build {
    display: none;
    font-family: var(--mono);
    font-size: clamp(13px, 1.4vw, 16px);
    line-height: 1.7;
    color: var(--build-dim);
  }
  :global(html[data-reading='builder']) .sub-audit { display: none; }
  :global(html[data-reading='builder']) .sub-build { display: block; }

  /* Lens toggle */
  .lens-toggle {
    display: inline-flex;
    align-items: stretch;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--audit-line);
    outline: none;
    user-select: none;
    margin-bottom: var(--s-5);
  }
  :global(html[data-reading='builder']) .lens-toggle { border-color: var(--build-line); }
  .indicator {
    position: absolute;
    top: 0; bottom: 0; left: 0;
    width: 50%;
    background: var(--audit-accent);
    opacity: 0.08;
    pointer-events: none;
    transition: left var(--dur) var(--ease);
  }
  :global(html[data-reading='builder']) .indicator {
    left: 50%;
    background: var(--build-accent);
  }
  .lens-toggle button {
    padding: 10px 22px;
    cursor: pointer;
    border: 0;
    background: transparent;
    font-family: var(--mono);
    font-size: var(--fs-label);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--audit-dim);
    opacity: 0.5;
    transition: color var(--dur) var(--ease), opacity var(--dur) var(--ease);
  }
  .divider { width: 1px; align-self: stretch; background: var(--audit-line); }
  :global(html[data-reading='builder']) .divider { background: var(--build-line); }
  .lens-toggle button[aria-pressed='true'] { color: var(--audit-accent); opacity: 1; }
  :global(html[data-reading='builder']) .lens-toggle button { color: var(--build-dim); }
  :global(html[data-reading='builder']) .lens-toggle button[aria-pressed='true'] { color: var(--build-accent); }
  .lens-toggle:focus-visible { outline: 2px solid var(--audit-accent); outline-offset: 3px; }
  :global(html[data-reading='builder']) .lens-toggle:focus-visible { outline-color: var(--build-accent); }

  /* Credentials */
  .credentials {
    font-size: var(--fs-small);
    color: var(--audit-dim);
    border-top: 1px solid var(--audit-line);
    padding-top: var(--s-4);
  }
  :global(html[data-reading='builder']) .credentials {
    color: var(--build-dim);
    border-color: var(--build-line);
  }
  .credentials-build { display: none; }
  :global(html[data-reading='builder']) .credentials-audit { display: none; }
  :global(html[data-reading='builder']) .credentials-build { display: block; }

  /* Seam */
  .seam {
    height: 120px;
    background: linear-gradient(to bottom, var(--audit-bg), var(--win-bg));
  }
  :global(html[data-reading='builder']) .seam {
    background: linear-gradient(to bottom, var(--build-bg), var(--win-bg));
  }

  /* Mobile: footnote appears below headline as tooltip-like block */
  @media (max-width: 720px) {
    .annotation-layer {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .margin {
      display: none;
    }
    .main-text {
      order: 1;
    }
  }
</style>

<script>
  import { setReading, getReading, onReading, type Reading } from '../lib/reading.ts';

  // ---- Name distortion on hover (canvas) ----
  const nameEl = document.getElementById('name-heading');
  const canvas = document.getElementById('name-canvas') as HTMLCanvasElement | null;
  const wrap = document.getElementById('name-wrap');

  // Assigned inside the guard below; declared here so the hero intro
  // timeline (module scope) can call it once the arrival sequence completes.
  let setupCanvas: () => void = () => {};

  if (nameEl && canvas && wrap) {
    const ctx = canvas.getContext('2d')!;
    const source = document.createElement('canvas');
    const srcCtx = source.getContext('2d')!;
    // Two extra copies of the glyphs, tinted and drawn at a slight offset
    // from the main pass with a 'lighter' blend — chromatic aberration,
    // so the warped strokes fringe red/cyan instead of staying flat black.
    const sourceRed = document.createElement('canvas');
    const srcRedCtx = sourceRed.getContext('2d')!;
    const sourceCyan = document.createElement('canvas');
    const srcCyanCtx = sourceCyan.getContext('2d')!;
    const dpr = window.devicePixelRatio || 1;
    // CSS text-transform: uppercase doesn't apply to canvas fillText, so the
    // canvas-drawn copy must spell out the uppercase form itself.
    const NAME = 'SAQLAIN MOMIN';

    const TILE = 4;
    const RADIUS = 130;
    const STRENGTH = 36;
    const BLEED = 4;
    const PAD = STRENGTH + 8;

    let w = 0, h = 0;
    let hovering = false;
    let mx = 0, my = 0;
    let raf = 0;
    let intensity = 0;
    let initialized = false;

    function renderSource() {
      const style = getComputedStyle(nameEl!);
      const rootStyle = getComputedStyle(document.documentElement);
      const isBuilder = getReading() === 'builder';
      const font = `${style.fontWeight} ${style.fontSize} ${style.fontFamily}`;
      const fg = rootStyle.getPropertyValue(isBuilder ? '--build-dim' : '--audit-dim').trim();

      for (const [c, fill] of [
        [srcCtx, fg],
        [srcRedCtx, '#c1453a'],
        [srcCyanCtx, '#3e8f95'],
      ] as const) {
        c.setTransform(dpr, 0, 0, dpr, 0, 0);
        c.clearRect(0, 0, w, h);
        c.font = font;
        c.letterSpacing = style.letterSpacing;
        c.fillStyle = fill;
        c.textAlign = 'center';
        c.textBaseline = 'middle';
        c.fillText(NAME, w / 2, h / 2);
      }
    }

    setupCanvas = function () {
      const rect = nameEl!.getBoundingClientRect();
      w = rect.width + PAD * 2;
      h = rect.height + PAD * 2;
      canvas!.width = w * dpr;
      canvas!.height = h * dpr;
      canvas!.style.width = w + 'px';
      canvas!.style.height = h + 'px';
      source.width = w * dpr;
      source.height = h * dpr;
      sourceRed.width = w * dpr;
      sourceRed.height = h * dpr;
      sourceCyan.width = w * dpr;
      sourceCyan.height = h * dpr;
      renderSource();
      drawClean();
      nameEl!.classList.add('canvas-active');
      initialized = true;
    };

    function drawClean() {
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.clearRect(0, 0, w * dpr, h * dpr);
      ctx.drawImage(source, 0, 0);
    }

    function noise(x: number, y: number, t: number): number {
      return Math.sin(x * 0.07 + t * 2.2) * Math.cos(y * 0.11 - t * 1.6)
           + Math.sin(x * 0.05 - y * 0.06 + t * 1.3) * 0.8
           + Math.sin(x * 0.16 + y * 0.13 - t * 2.6) * 0.4;
    }

    function drawDistorted() {
      const t = performance.now() * 0.001;
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.clearRect(0, 0, w * dpr, h * dpr);

      const str = STRENGTH * intensity;

      for (let gy = 0; gy < h; gy += TILE) {
        for (let gx = 0; gx < w; gx += TILE) {
          const tw = Math.min(TILE, w - gx);
          const th = Math.min(TILE, h - gy);
          const tcx = gx + tw / 2;
          const tcy = gy + th / 2;
          const ddx = tcx - mx;
          const ddy = tcy - my;
          const dist = Math.sqrt(ddx * ddx + ddy * ddy);

          let sx = gx, sy = gy;
          let power = 0;
          if (dist < RADIUS) {
            const norm = 1 - dist / RADIUS;
            power = norm * norm * (3 - 2 * norm);
            const nx = noise(gx, gy, t);
            const ny = noise(gx + 137, gy + 237, t);
            sx = gx + nx * power * str;
            sy = gy + ny * power * str * 0.8;
          }
          sx = Math.max(0, Math.min(w - tw, sx));
          sy = Math.max(0, Math.min(h - th, sy));

          if (power > 0.02) {
            const bleed = BLEED * power;
            ctx.globalCompositeOperation = 'lighter';
            ctx.drawImage(
              sourceRed,
              sx * dpr, sy * dpr, tw * dpr, th * dpr,
              (gx - bleed) * dpr, gy * dpr, tw * dpr, th * dpr
            );
            ctx.drawImage(
              sourceCyan,
              sx * dpr, sy * dpr, tw * dpr, th * dpr,
              (gx + bleed) * dpr, gy * dpr, tw * dpr, th * dpr
            );
            ctx.globalCompositeOperation = 'source-over';
          }

          ctx.drawImage(
            source,
            sx * dpr, sy * dpr, tw * dpr, th * dpr,
            gx * dpr, gy * dpr, tw * dpr, th * dpr
          );
        }
      }
    }

    function tick() {
      if (hovering && intensity < 1) intensity = Math.min(1, intensity + 0.06);
      if (!hovering && intensity > 0) intensity = Math.max(0, intensity - 0.04);

      if (intensity > 0.001) {
        drawDistorted();
        raf = requestAnimationFrame(tick);
      } else {
        drawClean();
        raf = 0;
      }
    }

    function startLoop() { if (!raf) raf = requestAnimationFrame(tick); }

    wrap!.addEventListener('mouseenter', () => { hovering = true; startLoop(); });
    wrap!.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = canvas!.getBoundingClientRect();
      mx = e.clientX - rect.left;
      my = e.clientY - rect.top;
    });
    wrap!.addEventListener('mouseleave', () => { hovering = false; startLoop(); });

    // Canvas setup is deferred until after the name slide-up completes,
    // because setupCanvas() makes the h1 transparent (canvas-active) —
    // a transparent element inside the clip mask would be invisible during the reveal.
    window.addEventListener('resize', () => { if (nameEl!.classList.contains('canvas-active')) setupCanvas(); });
    onReading(() => { if (!initialized) return; renderSource(); if (intensity <= 0) drawClean(); });

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      canvas!.style.display = 'none';
      nameEl!.classList.remove('canvas-active');
    }
  }

  // ---- Lens toggle ----
  const toggle = document.getElementById('lens-toggle');
  if (toggle) {
    const btns = Array.from(toggle.querySelectorAll<HTMLButtonElement>('button'));

    function sync(r: Reading) {
      btns.forEach((b) =>
        b.setAttribute('aria-pressed', String(b.dataset.set === r))
      );
      toggle!.setAttribute('aria-valuenow', r === 'builder' ? '1' : '0');
      toggle!.setAttribute('aria-valuetext', `${r} reading`);
    }

    btns.forEach((b) =>
      b.addEventListener('click', () =>
        setReading(b.dataset.set === 'builder' ? 'builder' : 'auditor')
      )
    );

    toggle.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault(); setReading('auditor');
      } else if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault(); setReading('builder');
      }
    });

    onReading(sync);
    sync(getReading());
  }

  // ---- Footnote data ----
  const FOOTNOTES: Record<Reading, Record<string, string>> = {
    auditor: {
      '3': 'Risk as in: the structural gap between what frameworks mandate and what organisations actually do. Compliance theatre vs. actual controls.',
      '4': 'ISO 27001, ISO 27701, ISO 22301 — Lead Auditor in all three. Not checkboxes. Each is a different way of asking: what happens when this fails?',
      '5': 'CyberAssess: a multi-framework gap assessment platform. Six compliance frameworks, two-call Claude pipeline, deterministic scoring.',
      '6': 'The gap between human security cycles and machine-speed iteration. AI task autonomy doubling every 89 days. This is the divergence I track and build into.',
    },
    builder: {
      '3': 'scoring.py — deterministic, server-side. Claude outputs qualitative strings, the code decides the number. Never let the model compute scores.',
      '4': '41 requirements across 6 chapters, defined as Python dicts. Version-controlled, embeddable in prompts, never stored in the database.',
      '5': 'Python 3.13 · FastAPI · Anthropic SDK · SQLAlchemy · Jinja2 + HTMX · Swift · n8n. The model writes language; the code decides the number.',
      '6': 'machinePath(progress) — the exponential curve from ClosingWindow. Human security cycles are linear. The shaded area between them is where I work.',
    },
  };

  // ---- DOM refs ----
  const sups = document.querySelectorAll<HTMLElement>('.headline sup[data-ref]');
  const slot = document.querySelector<HTMLElement>('.fn-slot');
  const slotNum = document.querySelector<HTMLElement>('.fn-slot-num');
  const slotText = document.querySelector<HTMLElement>('.fn-slot-text');
  const hint = document.querySelector<HTMLElement>('.fn-hint');

  function showFn(refNum: string) {
    const r = getReading();
    const text = FOOTNOTES[r]?.[refNum];
    if (!slot || !slotNum || !slotText || !text) return;
    slotNum.textContent = refNum;
    slotText.textContent = text;
    slot.classList.add('active');
    hint?.classList.add('hidden');
  }

  function hideFn() {
    slot?.classList.remove('active');
    hint?.classList.remove('hidden');
    if (slotNum) slotNum.textContent = '';
    if (slotText) slotText.textContent = '';
  }

  // Re-render active footnote when reading changes mid-hover
  let activeRef: string | null = null;
  onReading(() => { if (activeRef) showFn(activeRef); });

  sups.forEach((sup) => {
    sup.addEventListener('mouseenter', () => { activeRef = sup.dataset.ref ?? null; if (activeRef) showFn(activeRef); });
    sup.addEventListener('mouseleave', () => { activeRef = null; hideFn(); });
    sup.addEventListener('focus',      () => { activeRef = sup.dataset.ref ?? null; if (activeRef) showFn(activeRef); });
    sup.addEventListener('blur',       () => { activeRef = null; hideFn(); });
  });

  // setupCanvas() makes the h1 transparent in favor of drawing it on the
  // canvas — skip entirely under reduced motion, where that canvas is
  // hidden by the guard above and the h1 needs to stay visible as plain text.
  // Also wait for the arrive slide-up to finish: it animates the h1's own
  // opacity/transform, so swapping to the canvas (a second, separately
  // composited layer) mid-animation would pop instead of handing off clean.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const wrapEl = document.getElementById('name-wrap');
    const arrived = wrapEl
      ? new Promise<void>((resolve) => {
          wrapEl.addEventListener('animationend', () => resolve(), { once: true });
        })
      : Promise.resolve();
    Promise.all([document.fonts.ready, arrived]).then(setupCanvas);
  }

  // ---- Scroll cue ----
  const scrollCue = document.getElementById('scroll-cue');
  if (scrollCue) {
    let ticking = false;
    const FADE_VH = 0.3; // fully gone by 30% of viewport height scrolled
    function update() {
      const opacity = Math.max(0, 1 - window.scrollY / (window.innerHeight * FADE_VH));
      scrollCue!.style.opacity = String(opacity);
    }
    // CSS Animations win the cascade over plain inline styles for as long as
    // they're in effect — with fill-mode: forwards that's forever, which
    // would silently block the scroll-driven opacity below. Drop the
    // animation once it's done so the inline style takes over cleanly.
    scrollCue.addEventListener('animationend', () => {
      scrollCue!.style.animation = 'none';
      update(); // seed the resting opacity before clearing the fill — without
                // this it'd snap back to the base rule's opacity: 0 first.
    }, { once: true });
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(() => { ticking = false; update(); });
        }
      },
      { passive: true }
    );
  }

</script>
