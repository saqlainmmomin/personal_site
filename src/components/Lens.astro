---
// The Lens: dual-readable hero.
// Desktop (>=900px, fine pointer): a draggable seam reveals Builder on the left
// over the Auditor base. Mobile / coarse pointer: a Builder/Auditor toggle
// crossfades between readings. Keyboard: the seam is a slider; the toggle is
// always available. Loads on the Auditor reading.
---

<section class="lens" id="lens" data-reading="auditor" aria-label="Introduction">
  <div class="stage">
    <!-- Auditor base layer -->
    <div class="pane pane-audit">
      <div class="pane-inner">
        <p class="eyebrow">Cyber Strategy &amp; Governance</p>
        <h1>I assess where systems break.</h1>
        <p class="lead">
          Four years auditing controls at enterprise scale. I know why a control
          exists, not just that someone ticked the box.
        </p>
      </div>
    </div>

    <!-- Builder overlay (clipped on desktop, crossfaded on mobile) -->
    <div class="pane pane-build" aria-hidden="false">
      <div class="pane-inner">
        <p class="eyebrow">build &amp; ship</p>
        <h1>I build security tools.</h1>
        <p class="lead">
          Async Python, FastAPI, the Anthropic SDK, Swift, n8n. Understand by
          shipping.
        </p>
      </div>
    </div>

    <!-- Seam = slider handle (desktop only) -->
    <div
      class="seam"
      id="seam"
      role="slider"
      tabindex="0"
      aria-label="Reading lens: Auditor to Builder"
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow="0"
      aria-valuetext="Auditor reading"
    >
      <span class="knob" aria-hidden="true">
        <svg width="20" height="14" viewBox="0 0 20 14" fill="none" aria-hidden="true">
          <path d="M7 2 2 7l5 5M13 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </div>
  </div>

  <div class="bar">
    <p class="thread">
      I see risk at the enterprise level, and I build the tools to close the gaps
      I find.
    </p>
    <div class="controls">
      <div class="toggle" role="group" aria-label="Choose reading">
        <button type="button" data-set="auditor" aria-pressed="true">Auditor</button>
        <button type="button" data-set="builder" aria-pressed="false">Builder</button>
      </div>
      <span class="hint mono" id="lens-hint">drag, or switch reading</span>
    </div>
  </div>
</section>

<style>
  .lens {
    position: relative;
    background: var(--audit-bg);
    transition: background var(--dur) var(--ease);
  }
  .lens[data-reading='builder'] {
    background: var(--build-bg);
  }

  .stage {
    position: relative;
    height: 100svh;
    min-height: 560px;
    overflow: hidden;
  }

  .pane {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
  }
  .pane-inner {
    width: 100%;
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  /* Auditor base */
  .pane-audit {
    background: var(--audit-bg);
    color: var(--audit-fg);
    justify-content: flex-end;
    text-align: right;
    z-index: 1;
  }
  .pane-audit .pane-inner { display: flex; flex-direction: column; align-items: flex-end; }
  .pane-audit .eyebrow { color: var(--audit-accent); }
  .pane-audit h1 { font-family: var(--serif); font-weight: 600; }
  .pane-audit .lead { color: var(--audit-dim); }

  /* Builder overlay */
  .pane-build {
    background: var(--build-bg);
    color: var(--build-fg);
    justify-content: flex-start;
    text-align: left;
    z-index: 2;
    /* --split = percent of width (from the left) showing Builder. 0 = hidden. */
    clip-path: inset(0 calc(100% - var(--split, 0%)) 0 0);
  }
  .pane-build .eyebrow { color: var(--build-accent); }
  .pane-build h1 {
    font-family: var(--mono);
    font-weight: 500;
    letter-spacing: -0.03em;
    font-size: clamp(36px, 5.6vw, 72px);
  }
  .pane-build .lead { font-family: var(--mono); color: var(--build-dim); font-size: clamp(15px, 1.7vw, 19px); line-height: 1.7; }

  h1 {
    font-size: var(--fs-display);
    line-height: 0.98;
    letter-spacing: -0.02em;
    max-width: 14ch;
  }
  .eyebrow { margin-bottom: var(--s-5); }
  .lead { font-size: var(--fs-lead); line-height: 1.45; max-width: 30ch; margin-top: var(--s-5); }

  /* Seam */
  .seam {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--split, 0%);
    width: 2px;
    background: var(--build-accent);
    z-index: 5;
    transform: translateX(-1px);
    cursor: ew-resize;
    touch-action: none;
  }
  .seam::before {
    /* widen the hit area */
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: -16px;
    right: -16px;
  }
  .knob {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--build-accent);
    color: #04131f;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 22px rgba(0, 0, 0, 0.35);
    transition: transform 150ms var(--ease);
  }
  .seam:hover .knob,
  .seam:focus-visible .knob { transform: translate(-50%, -50%) scale(1.08); }
  .seam:focus-visible { outline: none; }
  .seam:focus-visible .knob { box-shadow: 0 0 0 3px var(--win-bg), 0 0 0 5px var(--build-accent); }

  /* Bar: thread + controls */
  .bar {
    position: relative;
    z-index: 6;
    padding: var(--s-6) var(--gutter) var(--s-7);
    background: var(--audit-bg);
    color: var(--audit-fg);
    border-top: 1px solid var(--audit-line);
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease), border-color var(--dur) var(--ease);
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
    align-items: center;
    text-align: center;
  }
  .lens[data-reading='builder'] .bar {
    background: var(--build-bg);
    color: var(--build-fg);
    border-color: var(--build-line);
  }
  .thread {
    font-family: var(--serif);
    font-style: italic;
    font-size: var(--fs-lead);
    line-height: 1.4;
    max-width: 34ch;
  }
  .lens[data-reading='builder'] .thread { font-family: var(--mono); font-style: normal; font-size: var(--fs-body); }

  .controls { display: flex; align-items: center; gap: var(--s-5); flex-wrap: wrap; justify-content: center; }
  .toggle {
    display: inline-flex;
    border: 1px solid var(--audit-line);
  }
  .lens[data-reading='builder'] .toggle { border-color: var(--build-line); }
  .toggle button {
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    padding: 9px 18px;
    background: transparent;
    color: inherit;
    border: 0;
    cursor: pointer;
    opacity: 0.6;
    transition: opacity var(--dur) var(--ease), background var(--dur) var(--ease);
  }
  .toggle button[aria-pressed='true'] { opacity: 1; }
  .lens[data-reading='auditor'] .toggle button[data-set='auditor'] { background: var(--audit-bg-2); }
  .lens[data-reading='builder'] .toggle button[data-set='builder'] { background: var(--build-bg-2); }
  .hint { font-size: 11px; letter-spacing: 0.1em; opacity: 0.55; }

  /* ---- Mobile / coarse pointer: no seam, toggle crossfades ---- */
  @media (max-width: 899px), (pointer: coarse) {
    .seam { display: none; }
    .pane-build {
      clip-path: none;
      opacity: 0;
      transition: opacity 180ms var(--ease);
    }
    .lens[data-reading='builder'] .pane-build { opacity: 1; }
    /* full-width, left-aligned readings on small screens */
    .pane-audit { justify-content: flex-start; text-align: left; }
    .pane-audit .pane-inner { align-items: flex-start; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pane-build { transition: none; }
  }
</style>

<script>
  import { setReading, onReading } from '../lib/reading.ts';

  const lens = document.getElementById('lens') as HTMLElement | null;
  const seam = document.getElementById('seam') as HTMLElement | null;
  const hint = document.getElementById('lens-hint');
  if (lens && seam) {
    const stage = lens.querySelector('.stage') as HTMLElement;
    const toggleBtns = Array.from(
      lens.querySelectorAll<HTMLButtonElement>('.toggle button')
    );

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const isDesktop = () =>
      window.matchMedia('(min-width: 900px)').matches &&
      window.matchMedia('(pointer: fine)').matches;

    // reveal: 0 = full Auditor, 100 = full Builder
    let reveal = 0;
    let internal = false; // guards against echoing our own reading changes

    const valueText = (v: number) =>
      v <= 4 ? 'Auditor reading' : v >= 96 ? 'Builder reading' : 'Both readings';

    function apply(v: number) {
      reveal = Math.max(0, Math.min(100, v));
      lens!.style.setProperty('--split', reveal + '%');
      const reading = reveal >= 50 ? 'builder' : 'auditor';
      lens!.dataset.reading = reading;
      seam!.setAttribute('aria-valuenow', String(Math.round(reveal)));
      seam!.setAttribute('aria-valuetext', valueText(reveal));
      toggleBtns.forEach((b) =>
        b.setAttribute('aria-pressed', String(b.dataset.set === reading))
      );
      internal = true;
      setReading(reading);
      internal = false;
    }

    // The Work toggle can change the reading while the hero is offscreen; when
    // the user scrolls back, the seam should match. Snap to match external changes.
    onReading((r) => {
      if (internal) return;
      animateTo(r === 'builder' ? 100 : 0);
    });

    // Animated tween (skipped under reduced motion)
    function animateTo(target: number, duration = 520) {
      if (reduceMotion.matches) {
        apply(target);
        return;
      }
      const start = reveal;
      const t0 = performance.now();
      function step(now: number) {
        const p = Math.min(1, (now - t0) / duration);
        const eased = 1 - Math.pow(1 - p, 3);
        apply(start + (target - start) * eased);
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    apply(0);

    // Hint copy matches the available mechanic (no drag when the seam is hidden).
    if (hint && getComputedStyle(seam).display === 'none') {
      hint.textContent = 'switch reading';
    }

    // ---- Drag (desktop) ----
    let dragging = false;
    function fromClientX(clientX: number) {
      const rect = stage.getBoundingClientRect();
      apply(((clientX - rect.left) / rect.width) * 100);
    }
    seam.addEventListener('pointerdown', (e) => {
      if (!isDesktop()) return;
      dragging = true;
      seam!.setPointerCapture(e.pointerId);
      e.preventDefault();
    });
    seam.addEventListener('pointermove', (e) => {
      if (dragging) fromClientX(e.clientX);
    });
    const endDrag = () => (dragging = false);
    seam.addEventListener('pointerup', endDrag);
    seam.addEventListener('pointercancel', endDrag);

    // ---- Keyboard (slider) ----
    seam.addEventListener('keydown', (e) => {
      const map: Record<string, number> = {
        ArrowRight: reveal + 5,
        ArrowUp: reveal + 5,
        ArrowLeft: reveal - 5,
        ArrowDown: reveal - 5,
        PageUp: reveal + 25,
        PageDown: reveal - 25,
        Home: 0,
        End: 100,
      };
      if (e.key in map) {
        e.preventDefault();
        animateTo(map[e.key], 160);
      }
    });

    // ---- Toggle ----
    toggleBtns.forEach((b) =>
      b.addEventListener('click', () => animateTo(b.dataset.set === 'builder' ? 100 : 0))
    );

    // ---- One-time discoverability hint (desktop, motion allowed) ----
    function runHint() {
      if (reduceMotion.matches || !isDesktop()) return;
      // slide out to show Builder, then rest with a sliver visible
      setTimeout(() => animateTo(60, 700), 520);
      setTimeout(() => animateTo(14, 700), 1500);
      setTimeout(() => {
        if (hint) hint.style.opacity = '0.3';
      }, 2600);
    }
    // Run shortly after the module executes (DOM is already parsed); avoids
    // depending on the load event, which may have already fired for module scripts.
    setTimeout(runHint, 400);
  }
</script>
