---
// One dual-readable project row. Both readings render and occupy the same grid
// cell; CSS shows one based on html[data-reading], crossfading on change.
export interface Reading {
  description: string;
  body: string;
  meta: string;
}
export interface Project {
  tag: string;
  name: string;
  lead?: boolean;
  builder: Reading;
  auditor: Reading;
  // Filled from the per-project link map. null until confirmed.
  link?: { label: string; href: string } | null;
  image?: {
    src: string;
    webp?: string;
    alt: string;
    poster?: string;
    video?: string;
    label: string;
  };
}
const { project } = Astro.props as { project: Project };
const { tag, name, lead, builder, auditor, link, image } = project;
---

<article class={`row${lead ? ' lead' : ''}`}>
  <div class="tag mono">{tag}</div>
  <div class="readings">
    <h3>{name}</h3>
    <div class="reading-stack">
      <div class="reading reading-audit">
        <p class="desc">{auditor.description}</p>
        <p class="body">{auditor.body}</p>
        <div class="meta mono">{auditor.meta}</div>
      </div>
      <div class="reading reading-build" aria-hidden="true">
        <p class="desc">{builder.description}</p>
        <p class="body">{builder.body}</p>
        <div class="meta mono">{builder.meta}</div>
      </div>
    </div>
    {
      link ? (
        <a class="link mono" href={link.href} target="_blank" rel="noopener">
          {link.label} &rarr;
        </a>
      ) : (
        <span class="link mono case">case study</span>
      )
    }
    {image && (
      <figure class="preview">
        <div class="preview-bar mono">{image.label}</div>
        {image.video ? (
          <>
            <video autoplay muted loop playsinline poster={image.poster} class="preview-video">
              <source src={image.video} type="video/mp4" />
            </video>
            <img src={image.poster} alt={image.alt} class="preview-poster" aria-hidden="true" />
          </>
        ) : (
          <picture>
            {image.webp && <source type="image/webp" srcset={image.webp} />}
            <img src={image.src} alt={image.alt} loading="lazy" decoding="async" />
          </picture>
        )}
      </figure>
    )}
  </div>
</article>

<style>
  .row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--s-6);
    padding: var(--s-7) 0;
    border-bottom: 1px solid var(--audit-line);
    align-items: baseline;
  }
  :global(html[data-reading='builder']) .row { border-color: var(--build-line); }
  .row.lead { padding: var(--s-8) 0; }

  .tag {
    font-size: var(--fs-label);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--audit-accent);
    padding-top: 6px;
  }
  :global(html[data-reading='builder']) .tag { color: var(--build-accent); }

  .readings { position: relative; }
  .reading-stack { position: relative; }
  .reading { transition: opacity 180ms var(--ease); }
  .reading-build { opacity: 0; visibility: hidden; position: absolute; top: 0; left: 0; width: 100%; }
  :global(html[data-reading='builder']) .reading-audit { opacity: 0; visibility: hidden; position: absolute; top: 0; left: 0; width: 100%; }
  :global(html[data-reading='builder']) .reading-build { opacity: 1; visibility: visible; position: static; }

  .readings > h3 {
    font-family: var(--serif);
    font-size: var(--fs-h3);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.18;
    max-width: 22ch;
  }
  :global(html[data-reading='builder']) .readings > h3 { font-family: var(--sans); font-weight: 500; }
  .row.lead .readings > h3 { font-size: clamp(24px, 3vw, 34px); }

  .desc {
    font-size: var(--fs-body);
    font-weight: 500;
    line-height: 1.4;
    margin-top: var(--s-3);
    max-width: 40ch;
  }
  .reading-audit .desc { font-family: var(--serif); color: var(--audit-fg); }
  .reading-build .desc { font-family: var(--mono); color: var(--build-fg); }

  .body {
    font-size: var(--fs-small);
    line-height: 1.55;
    margin-top: var(--s-3);
    max-width: 56ch;
  }
  .reading-audit .body { font-family: var(--serif); color: var(--audit-dim); }
  .reading-build .body { font-family: var(--mono); color: var(--build-dim); line-height: 1.7; }

  .meta { font-size: 12.5px; margin-top: var(--s-4); letter-spacing: 0.02em; }
  .reading-audit .meta { color: var(--audit-accent); }
  .reading-build .meta { color: var(--build-accent); }

  .link {
    display: inline-block;
    margin-top: var(--s-4);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }
  .link.case { border-bottom-style: dotted; opacity: 0.6; cursor: default; }
  :global(html[data-reading='builder']) .link { color: var(--build-fg); }

  .preview {
    margin-top: var(--s-6);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--audit-line);
    max-width: 640px;
  }
  :global(html[data-reading='builder']) .preview { border-color: var(--build-line); }
  .preview-bar {
    padding: 7px 14px;
    font-size: 11px;
    letter-spacing: 0.03em;
    color: var(--audit-dim);
    background: var(--audit-bg-2);
    border-bottom: 1px solid var(--audit-line);
  }
  :global(html[data-reading='builder']) .preview-bar {
    color: var(--build-dim);
    background: var(--build-bg-2);
    border-color: var(--build-line);
  }
  .preview video,
  .preview picture img { display: block; width: 100%; height: auto; }
  .preview-poster { display: none; width: 100%; height: auto; }

  @media (prefers-reduced-motion: reduce) {
    .reading { transition: none; }
    .preview-video { display: none; }
    .preview-poster { display: block; }
  }
  @media (max-width: 640px) {
    .row { grid-template-columns: 1fr; gap: var(--s-3); }
    .tag { padding-top: 0; }
    .preview { max-width: 100%; }
  }
</style>
