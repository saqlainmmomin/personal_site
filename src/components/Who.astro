---
// CV link points at /cv.pdf (placeholder file in public/). Replace with the
// real export before launch.
const facts = [
  { k: 'Role', v: 'Assistant Manager, Cyber Strategy & Governance, at KPMG' },
  { k: 'Certifications', v: 'ISO 27001, ISO 27701, ISO 22301 Lead Auditor' },
  { k: 'Education', v: 'B.Tech in Information Technology and MBA in Finance, NMIMS' },
  { k: 'Sectors', v: 'Financial services, fintech, SaaS' },
];
---

<section class="who" id="who" aria-labelledby="who-h">
  <div class="wrap">
    <p class="eyebrow">Who</p>
    <h2 id="who-h">The audit grounding.</h2>
    <p class="lead">
      Pre-certification readiness for ISO 27001, 27701, and 22301. Third-party
      risk program design for financial services and fintech. Technology risk
      assessments and board-level reporting.
    </p>

    <div class="impact">
      <h3 class="mono">Impact</h3>
      <ul>
        <li>Led 15+ security engagements across BFSI, real estate, and e-commerce</li>
        <li>Built vendor risk programs covering 50+ vendor ecosystems</li>
        <li>Delivered end-to-end compliance reviews against NIST CSF, OWASP Top 10, PCI DSS</li>
      </ul>
    </div>

    <dl class="facts">
      {
        facts.map((f) => (
          <div class="fact">
            <dt class="mono">{f.k}</dt>
            <dd>{f.v}</dd>
          </div>
        ))
      }
    </dl>

    <a class="cv mono" href="/cv.pdf" download>Download CV (PDF) &darr;</a>
  </div>
</section>

<style>
  .who {
    background: var(--audit-bg);
    color: var(--audit-fg);
    padding: var(--section-gap) 0;
    border-top: 1px solid var(--audit-line);
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  :global(html[data-reading='builder']) .who {
    background: var(--build-bg);
    color: var(--build-fg);
    border-top-color: var(--build-line);
  }
  .eyebrow { color: var(--audit-accent); margin-bottom: var(--s-4); }
  :global(html[data-reading='builder']) .eyebrow { color: var(--build-accent); }
  h2 { font-family: var(--serif); font-size: var(--fs-h2); font-weight: 600; letter-spacing: -0.02em; }
  :global(html[data-reading='builder']) h2 { font-family: var(--sans); font-weight: 500; }
  .lead { font-size: var(--fs-lead); color: var(--audit-dim); max-width: 52ch; margin-top: var(--s-4); line-height: 1.45; }
  :global(html[data-reading='builder']) .lead { color: var(--build-dim); font-family: var(--mono); font-size: var(--fs-body); }

  .impact { margin-top: var(--s-7); }
  .impact h3 {
    font-size: var(--fs-label);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--audit-accent);
    margin-bottom: var(--s-4);
  }
  :global(html[data-reading='builder']) .impact h3 { color: var(--build-accent); }
  .impact ul {
    list-style: none;
    display: grid;
    gap: var(--s-3);
    max-width: 56ch;
  }
  .impact li {
    font-size: var(--fs-body);
    line-height: 1.45;
    padding-left: 1.2em;
    position: relative;
  }
  .impact li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--audit-accent);
  }
  :global(html[data-reading='builder']) .impact li::before { color: var(--build-accent); }

  .facts { margin-top: var(--s-7); border-top: 1px solid var(--audit-line); }
  :global(html[data-reading='builder']) .facts { border-top-color: var(--build-line); }
  .fact {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: var(--s-5);
    padding: var(--s-4) 0;
    border-bottom: 1px solid var(--audit-line);
  }
  :global(html[data-reading='builder']) .fact { border-bottom-color: var(--build-line); }
  dt { font-size: var(--fs-label); letter-spacing: 0.08em; text-transform: uppercase; color: var(--audit-accent); padding-top: 4px; }
  :global(html[data-reading='builder']) dt { color: var(--build-accent); }
  dd { font-size: var(--fs-body); }

  .cv {
    display: inline-block;
    margin-top: var(--s-6);
    font-size: 13px;
    letter-spacing: 0.04em;
    text-decoration: none;
    border-bottom: 1px solid var(--audit-accent);
    color: var(--audit-accent);
    padding-bottom: 3px;
  }
  :global(html[data-reading='builder']) .cv {
    border-bottom-color: var(--build-accent);
    color: var(--build-accent);
  }
  @media (max-width: 560px) {
    .fact { grid-template-columns: 1fr; gap: var(--s-1); }
  }
</style>
