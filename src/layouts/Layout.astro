---
import '../styles/tokens.css';
import RetuneOverlay from '../components/RetuneOverlay';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Saqlain Momin - Cyber Strategy & Governance, security tooling',
  description =
    'I see risk at the enterprise level, and I build the tools to close the gaps I find. Cyber strategy and governance, ISO Lead Auditor, and security tooling built in Python and the Anthropic SDK.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;

const person = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Saqlain Momin',
  jobTitle: 'Assistant Manager, Cyber Strategy & Governance',
  email: 'mailto:saqlainmmomin@gmail.com',
  knowsAbout: [
    'Cyber strategy and governance',
    'ISO 27001',
    'ISO 27701',
    'ISO 22301',
    'Third-party risk management',
    'Agentic AI security',
    'Security tooling',
  ],
  // GitHub URL still pending.
  sameAs: ['https://www.linkedin.com/in/saqlain-musa/'],
};
---

<!doctype html>
<html lang="en" data-reading="auditor">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Preload the most-used faces above the fold: Big Shoulders Display 700/800
         render the LCP hero role + name; Mono 400 renders eyebrows, nav, labels. -->
    <link
      rel="preload"
      href="/fonts/big-shoulders-display-latin-700-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/big-shoulders-display-latin-800-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/ibm-plex-mono-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <meta name="theme-color" content="#0c0e13" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <script type="application/ld+json" set:html={JSON.stringify(person)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />
    {import.meta.env.DEV && <RetuneOverlay client:only="react" />}

    <script>
      import Lenis from 'lenis';

      const lenis = new Lenis({
        duration: 1.15,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      });
      (window as unknown as Record<string, unknown>).lenis = lenis;

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      // Reveal observer — one-shot: reveals on first intersection then stops watching
      const revealObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-revealed');
              revealObs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => revealObs.observe(el));
    </script>
  </body>
</html>